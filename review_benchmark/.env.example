# =============================================================================
#  Review Evaluation Framework — Environment Configuration
#  Copy this file to .env and fill in your values:
#      cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# DATA PATH
# Path to the root folder of Final_LLM_Reviewer_Data.
# Download/clone dataset then point this variable to it.
# Expected layout:
#   DATA_ROOT/
#     ICLR2024/
#       human_reviews/        {paper_id}.json
#       sea_iclr2024/         {paper_id}.txt
#       tree_iclr2024/        {paper_id}_review.json
#       reviewer2_iclr2024/   {paper_id}.txt
#       deepreview_iclr2024/  {paper_id}.json
#       cyclereview_iclr2024/ {paper_id}.json
#       papers/               {paper_id}.mmd  (full paper text)
#       paper_ids_50_iclr2024.txt
#     ICLR2025/   (same structure)
#     ICLR2026/   (same structure)
#     ICML2025/   (same structure)
#     Neurlps2025/ (NeurIPS 2025 — note folder name spelling)
# -----------------------------------------------------------------------------
DATA_ROOT=/path/to/Final_LLM_Reviewer_Data

# -----------------------------------------------------------------------------
# API KEYS — at least one evaluator backend is required
# -----------------------------------------------------------------------------

# Gemini (default evaluator backend)
# Get key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Mimo v2.5 Pro (alternative evaluator, used for robustness comparison)
# Get key at: https://platform.xiaomimimo.com/
MIMO_API_KEY=your_mimo_api_key_here
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# OpenAI (optional)
# OPENAI_API_KEY=your_openai_key_here

# Azure OpenAI (optional)
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# -----------------------------------------------------------------------------
# MODEL SETTINGS (optional overrides)
# -----------------------------------------------------------------------------
GEMINI_MODEL=gemini-2.5-flash-lite
MIMO_MODEL=mimo-v2.5-pro

