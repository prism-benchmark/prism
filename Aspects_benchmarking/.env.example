#
# PRISM benchmarking configuration.
# Copy this file to .env and fill in local values. Do not commit .env.
#

# Absolute path to the downloaded benchmark dataset root.
DATA_ROOT=/absolute/path/to/Final_LLM_Reviewer_Data

# Gemini evaluator backend.
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional OpenAI-compatible evaluator backend used for robustness checks.
MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro
MIMO_BASE_URL=

# Optional OpenAI/Azure OpenAI backends.
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
