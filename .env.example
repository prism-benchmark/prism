#
# PRISM — Unified environment configuration
# Copy this file to .env and fill in your values. Do NOT commit .env.
#
# This is the SINGLE source of truth for all environment variables.
# Both Aspects_benchmarking and LLM_reviewer read from here via ai_config.py.
#
# ── Model Selection ──────────────────────────────────────────────────────
# To choose which model each aspect/reviewer uses, edit llm_config.yaml.
# This .env file only stores API keys and credentials.
# See llm_config.yaml for per-aspect and per-reviewer model configuration.
#

# ═══════════════════════════════════════════════════════════════════════════
# Data
# ═══════════════════════════════════════════════════════════════════════════

# `python run.py --setup-data` writes this automatically.
DATA_ROOT=/absolute/path/to/PRISM/Data/input

# ═══════════════════════════════════════════════════════════════════════════
# Google / Gemini
# ═══════════════════════════════════════════════════════════════════════════

GOOGLE_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# OpenAI
# ═══════════════════════════════════════════════════════════════════════════

OPENAI_API_KEY=

# ═══════════════════════════════════════════════════════════════════════════
# Azure OpenAI
# ═══════════════════════════════════════════════════════════════════════════

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=

# ═══════════════════════════════════════════════════════════════════════════
# Xiaomi Mimo (OpenAI-compatible)
# ═══════════════════════════════════════════════════════════════════════════

# Legacy single key; combined with MIMO_API_KEYS when both are set.
MIMO_API_KEY=
# Preferred comma-separated keys for round-robin load balancing.
MIMO_API_KEYS=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1


# ═══════════════════════════════════════════════════════════════════════════
# Generic OpenAI-compatible LLM (used by novelty verification)
# ═══════════════════════════════════════════════════════════════════════════

LLM_API_KEY=
LLM_API_ENDPOINT=https://api.openai.com/v1

# Number of papers evaluated concurrently. Lower this if your provider returns
# rate-limit errors; increase it if your account and endpoint support more load.
PRISM_MAX_WORKERS=8

# ═══════════════════════════════════════════════════════════════════════════
# HuggingFace (for local model downloads)
# ═══════════════════════════════════════════════════════════════════════════

HF_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# Semantic Scholar API (optional, for higher rate limits)
# ═══════════════════════════════════════════════════════════════════════════

# SEMANTIC_SCHOLAR_API_KEY=
# Comma-separated for load balancing:
# SEMANTIC_SCHOLAR_API_KEYS=key1,key2,key3

# ═══════════════════════════════════════════════════════════════════════════
# Runtime overrides
# ═══════════════════════════════════════════════════════════════════════════

API_TIMEOUT=120
MAX_RETRIES=3
RETRY_DELAY=1

# ═══════════════════════════════════════════════════════════════════════════
# Network proxy (optional)
# ═══════════════════════════════════════════════════════════════════════════

# HTTP_PROXY=http://127.0.0.1:7893
# HTTPS_PROXY=http://127.0.0.1:7893
