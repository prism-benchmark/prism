#
# PRISM — Unified environment configuration
# Copy this file to .env and fill in your values. Do NOT commit .env.
#
# This is the SINGLE source of truth for all environment variables.
# Both Aspects_benchmarking and LLM_reviewer read from here via ai_config.py.
#

# ═══════════════════════════════════════════════════════════════════════════
# Data
# ═══════════════════════════════════════════════════════════════════════════

# Absolute path to the downloaded benchmark dataset root.
DATA_ROOT=/absolute/path/to/Final_LLM_Reviewer_Data

# ═══════════════════════════════════════════════════════════════════════════
# Google / Gemini
# ═══════════════════════════════════════════════════════════════════════════

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMP=0.0

# ═══════════════════════════════════════════════════════════════════════════
# OpenAI
# ═══════════════════════════════════════════════════════════════════════════

OPENAI_API_KEY=
GPT_MODEL=gpt-4o-mini
GPT_TEMP=1.0

# ═══════════════════════════════════════════════════════════════════════════
# Azure OpenAI
# ═══════════════════════════════════════════════════════════════════════════

AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ═══════════════════════════════════════════════════════════════════════════
# Xiaomi Mimo (OpenAI-compatible)
# ═══════════════════════════════════════════════════════════════════════════

MIMO_API_KEY=
MIMO_MODEL=mimo-v2.5-pro
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_TEMP=0.0

# ═══════════════════════════════════════════════════════════════════════════
# Bosch Devmate (Gemini proxy)
# ═══════════════════════════════════════════════════════════════════════════

DEVMATE_API_KEY=
DEVMATE_BASE_URL=https://devmate.bosch.com/api/v3
DEVMATE_PROXY=http://rb-proxy-apac.bosch.com:8080
DEVMATE_DISABLE_SSL_VERIFY=true
GEMINI_DEVMATE_MODEL=gemini-3-flash-preview

# ═══════════════════════════════════════════════════════════════════════════
# Generic OpenAI-compatible LLM (used by novelty verification)
# ═══════════════════════════════════════════════════════════════════════════

LLM_PROVIDER=openai
LLM_API_KEY=
LLM_API_ENDPOINT=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4o

# ═══════════════════════════════════════════════════════════════════════════
# HuggingFace (for local model downloads)
# ═══════════════════════════════════════════════════════════════════════════

HF_TOKEN=

# ═══════════════════════════════════════════════════════════════════════════
# Semantic Scholar API (optional, for higher rate limits)
# ═══════════════════════════════════════════════════════════════════════════

# SEMANTIC_SCHOLAR_API_KEY=
# Comma-separated for load balancing:
# SEMANTIC_SCHOLAR_API_KEYS=key1,key2,key3

# ═══════════════════════════════════════════════════════════════════════════
# Inference defaults (override per-provider temps above if needed)
# ═══════════════════════════════════════════════════════════════════════════

DEFAULT_MAX_OUTPUT_TOKENS=4096
LLM_MAX_TOKENS=64000
LLM_PROVIDER_CAP=64000
LLM_MAX_PROMPT_CHARS=250000
MAX_CONTEXT_CHARS=200000
API_TIMEOUT=120
MAX_RETRIES=30
RETRY_DELAY=5

# ═══════════════════════════════════════════════════════════════════════════
# Network proxy (optional)
# ═══════════════════════════════════════════════════════════════════════════

# HTTP_PROXY=http://127.0.0.1:7893
# HTTPS_PROXY=http://127.0.0.1:7893
