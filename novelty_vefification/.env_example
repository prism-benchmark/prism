#!/bin/bash
# ============================================================================
# OpenNovelty Environment Configuration Example
# ============================================================================
# Usage:
#   1. Copy this file to .env: cp .env_example .env
#   2. Fill in your actual API Keys and configurations
#   3. Load it: source .env (or pass via --llm-* flags)
# ============================================================================

# ============================================================================
# LLM API Configuration (Required)
# ============================================================================
# Purpose: Task 1 (claim extraction) and Task 3 (novelty verification)

export LLM_API_ENDPOINT="http://localhost:8080/v1"      # vLLM server endpoint
export LLM_API_KEY="not-needed"                         # vLLM doesn't require API key
export LLM_MODEL_NAME="LiquidAI/LFM2.5-1.2B-Instruct"   # Model served via vLLM
export LLM_PROVIDER="openai"                            # vLLM is OpenAI-compatible

# Examples for different providers:
# - vLLM local:  http://localhost:8080/v1 with model "LiquidAI/LFM2.5-1.2B-Instruct"
# - OpenRouter:  https://openrouter.ai/api/v1 with model "anthropic/claude-sonnet-4.5"
# - OpenAI:      https://api.openai.com/v1 with model "gpt-4o"
# - Google:      https://generativelanguage.googleapis.com/v1beta/openai/ with model "gemini-2.5-flash-lite"
# - Xiaomi:      https://api.xiaomimimo.com/v1 with model "mimo-v2.5-pro"

# ============================================================================
# Semantic Scholar API Keys (Optional — for higher rate limits in Task 2)
# ============================================================================
# Task 2 uses the public Semantic Scholar API (no key needed, 1 req/s).
# For higher throughput, add API keys (comma-separated):
# export SEMANTIC_SCHOLAR_API_KEYS="key1,key2,key3"

# ============================================================================
# Optional: Network Proxy
# ============================================================================
# export HTTP_PROXY="http://127.0.0.1:7893"
# export HTTPS_PROXY="http://127.0.0.1:7893"
